{
  "name": "Tab Extract",
  "version": "1.6.2",
  "description": "A simple & lightweight tool to reduce tab clutter, using just the address bar.",
  "manifest_version": 3,
  "{{chrome}}.update_url": "https://clients2.google.com/service/update2/crx",
  "{{chrome}}.minimum_chrome_version": "88.0.0.0",
  "omnibox": { "keyword": "ex" },
  "{{chrome}}.background": {
    "service_worker": "src/background.js"
  },
  "{{firefox}}.background": {
    "scripts": ["src/background.js"]
  },
  "icons": {
    "16": "icon_016.png",
    "32": "icon_032.png",
    "48": "icon_048.png",
    "128": "icon_128.png"
  },
  "permissions": ["tabs", "storage"],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "{5f19c5b2-8ef9-4f63-9d0b-d13bc476972a}",
      "strict_min_version": "109.0"
    }
  }
}
